<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel">

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">

            
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="Cog" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_SettingsHeader}" Classes="Header" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            
            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    MaxWidth="650" HorizontalAlignment="Left">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="AccountCircleOutline" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{DynamicResource L_SettAccount}" Classes="SubHeader" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto, 20, *, Auto">
                        <Border Grid.Column="0" Width="60" Height="60"
                                Background="{DynamicResource MainAccentBrush}" CornerRadius="30">
                            <TextBlock Text="RD" Foreground="White" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" FontWeight="Bold" FontSize="20"/>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{DynamicResource L_SettAdmin}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <mi:MaterialIcon Kind="EmailOutline" Width="13" Height="13"
                                                 Foreground="{DynamicResource TextDimBrush}"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="session_admin_01@reddice.flow"
                                           Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="3" Classes="MenuButton" Width="110" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <mi:MaterialIcon Kind="LogoutVariant" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource L_SettLogout}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            
            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    MaxWidth="650" HorizontalAlignment="Left">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="TuneVariant" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{DynamicResource L_SettGeneral}" Classes="SubHeader" VerticalAlignment="Center"/>
                    </StackPanel>

                    
                    <Grid ColumnDefinitions="*, 150">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Translate" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L_SettLangLabel}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L_SettLangCurrent}"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ToggleLanguage}"
                                Classes="MenuButton" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <mi:MaterialIcon Kind="SwapHorizontal" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource L_SettChangeBtn}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush2}"/>

                    
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="WeatherSunny" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L_SettThemeLabel}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L_SettThemeSub}"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding IsLightTheme}"
                                      OnContent="{DynamicResource L_SettLight}"
                                      OffContent="{DynamicResource L_SettDark}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Genre Management -->
            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    MaxWidth="650" HorizontalAlignment="Left">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="TagMultiple" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{DynamicResource L_SettGenreManagement}" Classes="SubHeader" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource L_SettGenreDescription}"
                               Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>

                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding NewGenreText}"
                                 PlaceholderText="{DynamicResource L_SettGenrePlaceholder}"
                                 Height="36"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"/>
                        <Button Grid.Column="1" Command="{Binding AddGenreCommand}"
                                Background="{DynamicResource MainAccentBrush}"
                                Foreground="White" Height="36" Padding="16,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Plus" Width="16" Height="16" Foreground="White"/>
                                <TextBlock Text="{DynamicResource L_SettAddBtn}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding GenreOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource MainAccentBrush}" CornerRadius="14"
                                        Padding="12,5" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Infographic Goals -->
            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    MaxWidth="650" HorizontalAlignment="Left">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="ChartBellCurve" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{DynamicResource L_SettInfographicGoals}" Classes="SubHeader" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, 120">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{DynamicResource L_SettStockLoadTarget}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource L_SettStockLoadDesc}"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Text="{Binding StockLoadGoal}"
                                 Height="34" TextAlignment="Center"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"/>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush2}"/>

                    <Grid ColumnDefinitions="*, 120">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{DynamicResource L_SettSalesTarget}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource L_SettSalesDesc}"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Text="{Binding SalesProgressGoal}"
                                 Height="34" TextAlignment="Center"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"/>
                    </Grid>
                </StackPanel>
            </Border>

            
            <Button Background="{DynamicResource MainAccentBrush}"
                    Foreground="White" FontWeight="Bold"
                    Padding="30,15" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="ContentSaveCheckOutline" Width="18" Height="18"/>
                    <TextBlock Text="{DynamicResource L_SettSaveAll}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
