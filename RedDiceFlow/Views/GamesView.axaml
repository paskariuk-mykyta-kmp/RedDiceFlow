<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RedDiceFlow.Views.GamesView">
    
    <StackPanel Margin="30" Spacing="25">
        <Grid ColumnDefinitions="*, Auto, 20, Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Product Inventory" Classes="Header"/>
                <TextBlock Text="Manage prices and stock levels" Foreground="{StaticResource TextDimBrush}" FontSize="14"/>
            </StackPanel>
            <TextBox Grid.Column="1" Width="300" Watermark="Search by SKU..." Classes="Modern" VerticalAlignment="Bottom"/>
            <Button Grid.Column="3" Content="+ Add Item" Background="{StaticResource MainRedBrush}" Padding="15,8" CornerRadius="6" VerticalAlignment="Bottom"/>
        </Grid>

        <Border Background="{StaticResource DarkBgBrush}" CornerRadius="12" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1" ClipToBounds="True">
            <StackPanel>
                <Border Background="{StaticResource GrayBorderBrush}" Padding="20,12">
                    <Grid ColumnDefinitions="2*, 1*, 1*, 1*, 100">
                        <TextBlock Grid.Column="0" Text="PRODUCT" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="1" Text="PRICE" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="2" Text="STOCK" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="3" Text="STATUS" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="4" Text="EDIT" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontWeight="Heavy" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <Border Classes="TableRow" Padding="20,15" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="2*, 1*, 1*, 1*, 100">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Cyberpunk 2077: Board Game" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="SKU: RD-7721" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="$89.99" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="14 pcs" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="3" Background="#1A3A1A" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="In Stock" Foreground="#4CAF50" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Button Grid.Column="4" Content="✏️" Background="Transparent" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Classes="TableRow" Padding="20,15">
                    <Grid ColumnDefinitions="2*, 1*, 1*, 1*, 100">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="D&amp;D Starter Set" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="SKU: RD-9005" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="$25.00" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="2 pcs" Foreground="#C3073F" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Border Grid.Column="3" Background="#3A1A1A" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Low Stock" Foreground="#C3073F" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Button Grid.Column="4" Content="✏️" Background="Transparent" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>