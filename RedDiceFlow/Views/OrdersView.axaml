<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:views="using:RedDiceFlow.Views"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.OrdersView"
             x:CompileBindings="False"
             Background="{DynamicResource AppBgBrush}">

    <UserControl.Resources>
        <views:StatusToColorConverter x:Key="StatusToColor"/>
        <views:StatusToDisplayConverter x:Key="StatusToDisplay"/>
        <views:StatusToShipVisibleConverter x:Key="StatusToShipVisible"/>
        <views:StatusToDeliverVisibleConverter x:Key="StatusToDeliverVisible"/>
        <views:StatusToCancelVisibleConverter x:Key="StatusToCancelVisible"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ClipboardListOutline" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"/>
                    <TextBlock Text="{DynamicResource L_OrdersHeader}"
                               Classes="Header"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource L_OrdersSub}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Border Background="{DynamicResource PanelBgBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1"
                    Padding="20">
                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="12">
                    <TextBox Grid.Column="0"
                             Text="{Binding OrderSearchPhone}"
                             PlaceholderText="{DynamicResource L_OrderSearch}"
                             Background="{DynamicResource PanelBgBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush2}"
                             Height="38"/>

                    <Button Grid.Column="1"
                            Command="{Binding SearchOrdersCommand}"
                            Background="{DynamicResource MainAccentBrush}"
                            Foreground="White"
                            Padding="20,0"
                            Height="38">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Magnify" Width="18" Height="18" Foreground="White"/>
                            <TextBlock Text="{DynamicResource L_OrderSearchButton}" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding ReloadOrdersCommand}"
                            Background="{DynamicResource BorderBrush2}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="14,0"
                            Height="38">
                        <mi:MaterialIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBgBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1">
                <StackPanel Spacing="0">
                    <TextBlock Text="{DynamicResource L_OrderList}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="20,20,20,10"/>

                    <ListBox ItemsSource="{Binding Orders}"
                             SelectedItem="{Binding SelectedOrder}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="520">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush2}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,14">
                                    <Grid ColumnDefinitions="50, 1.5*, 100, 100, Auto" ColumnSpacing="12">
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="18"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayNumber}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CustomerName}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding CustomerPhone}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding ItemsCount, StringFormat='{}{0} items'}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{DynamicResource L_OrderTotalLabel}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2} $'}"
                                                       Foreground="{DynamicResource AccentGreenBrush}"
                                                       FontWeight="Bold" FontSize="14"/>
                                        </StackPanel>

                                        <Border Grid.Column="3" CornerRadius="6" Padding="10,4"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToDisplay}}"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                                        </Border>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Button IsVisible="{Binding Status, Converter={StaticResource StatusToShipVisible}}"
                                                    Command="{Binding DataContext.ShipOrderCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource MainAccentBrush}"
                                                    Foreground="White"
                                                    Height="30"
                                                    Padding="12,0"
                                                    FontSize="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="TruckDelivery" Width="14" Height="14" Foreground="White"/>
                                                    <TextBlock Text="{DynamicResource L_ShipBtn}" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                            <Button IsVisible="{Binding Status, Converter={StaticResource StatusToDeliverVisible}}"
                                                    Command="{Binding DataContext.DeliverOrderCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource AccentGreenBrush}"
                                                    Foreground="White"
                                                    Height="30"
                                                    Padding="12,0"
                                                    FontSize="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="CheckCircle" Width="14" Height="14" Foreground="White"/>
                                                    <TextBlock Text="{DynamicResource L_DeliverBtn}" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                            <Button IsVisible="{Binding Status, Converter={StaticResource StatusToCancelVisible}}"
                                                    Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource AccentRedBrush}"
                                                    Foreground="White"
                                                    Height="30"
                                                    Padding="12,0"
                                                    FontSize="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="CloseCircleOutline" Width="14" Height="14" Foreground="White"/>
                                                    <TextBlock Text="{DynamicResource L_CancelOrder}"
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteOrderCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource AccentRedBrush}"
                                                    Foreground="White"
                                                    Height="30"
                                                    Padding="12,0"
                                                    FontSize="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14" Foreground="White"/>
                                                    <TextBlock Text="{DynamicResource L_DeleteOrderBtn}" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
