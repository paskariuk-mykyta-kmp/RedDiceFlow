<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.OrdersView"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource AppBgBrush}">

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ClipboardListOutline" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"/>
                    <TextBlock Text="{Binding L_OrdersHeader}"
                               Classes="Header"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding L_OrdersSub}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Border Background="{DynamicResource PanelBgBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1"
                    Padding="20">
                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="12">
                    <TextBox Grid.Column="0"
                             Text="{Binding OrderSearchPhone}"
                             PlaceholderText="{Binding L_OrderSearch}"
                             Background="{DynamicResource PanelBgBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush2}"
                             Height="38"/>

                    <Button Grid.Column="1"
                            Command="{Binding SearchOrdersCommand}"
                            Background="{DynamicResource MainAccentBrush}"
                            Foreground="White"
                            Padding="20,0"
                            Height="38">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Magnify" Width="18" Height="18" Foreground="White"/>
                            <TextBlock Text="{Binding L_OrderSearchButton}" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding ReloadOrdersCommand}"
                            Background="{DynamicResource BorderBrush2}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="14,0"
                            Height="38">
                        <mi:MaterialIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="1.1*, 1.4*" ColumnSpacing="20">
                <Border Grid.Column="0"
                        Background="{DynamicResource PanelBgBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding L_OrderList}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <ListBox ItemsSource="{Binding Orders}"
                                 SelectedItem="{Binding SelectedOrder}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="520">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Order">
                                    <Border BorderBrush="{DynamicResource BorderBrush2}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,10">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0"
                                                            Text="{Binding CustomerName}"
                                                            FontWeight="Bold"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                            Text="{Binding TotalPrice, StringFormat='{}{0:N2} $'}"
                                                            Foreground="{DynamicResource AccentGreenBrush}"
                                                            FontWeight="Bold"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0"
                                                            Text="{Binding CustomerPhone}"
                                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                                            FontSize="12"/>
                                                <TextBlock Grid.Column="1"
                                                            Text="{Binding ItemsCount, StringFormat='{}{0} items'}"
                                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                                            FontSize="12"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource PanelBgBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding L_OrderDetails}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding L_OrderNoSelection}"
                                   IsVisible="{Binding HasNoSelectedOrder}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <ItemsControl ItemsSource="{Binding SelectedOrderItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:OrderItem">
                                    <Border BorderBrush="{DynamicResource BorderBrush2}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,10">
                                        <Grid ColumnDefinitions="2*, 1*, 1*, 1*" ColumnSpacing="10">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProductName}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Genre}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Quantity, StringFormat='{}{0} pcs'}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding UnitPrice, StringFormat='{}{0:N2} $'}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding LineTotal, StringFormat='{}{0:N2} $'}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentGreenBrush}"
                                                       FontWeight="Bold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
