<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RedDiceFlow.Views.MainWindow"
        Title="Red Dice Flow - Store Manager"
        Background="{StaticResource DeepBgBrush}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="260, *">
        <StackPanel Grid.Column="0" Background="{StaticResource DarkBgBrush}">
            <StackPanel Margin="10,25">
                <Image Source="avares://RedDiceFlow/Assets/logo.png" Width="180" Height="180"/>
                <TextBlock Text="RED DICE FLOW" Foreground="{StaticResource MainRedBrush}" 
                           FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
            </StackPanel>
            
            <Button Content="Dashboard" Name="BtnDash" Classes="MenuButton" Click="OnMenuClick" Background="{StaticResource MainRedBrush}"/>
            <Button Content="Inventory" Name="BtnGames" Classes="MenuButton" Click="OnMenuClick"/>
            <Button Content="Analytics" Name="BtnAnalytic" Classes="MenuButton" Click="OnMenuClick"/>
            <Button Content="Settings" Name="BtnSettings" Classes="MenuButton" Click="OnMenuClick"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <TransitioningContentControl Name="MainContentArea">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.25" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>

            <Border VerticalAlignment="Bottom" Background="{StaticResource DarkBgBrush}" Height="30" Padding="15,0">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Store Management System Online" Foreground="{StaticResource StatusGreen}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="v1.0.5-final-ui" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>