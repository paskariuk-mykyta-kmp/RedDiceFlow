<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RedDiceFlow.ViewModels"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="RedDiceFlow.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Red Dice Flow - Store Manager"
        Background="{DynamicResource AppBgBrush}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.MenuButton">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.MenuButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBgBrush}"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="260, *">
        <StackPanel Grid.Column="0" Background="{DynamicResource PanelBgBrush}">
            <StackPanel Margin="10,25">
                <Image Source="avares://RedDiceFlow/Assets/logo.png" Width="180" Height="180"/>
                <TextBlock Text="RED DICE FLOW"
                           Foreground="{DynamicResource MainAccentBrush}"
                           FontSize="22"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="BtnDash" Classes="MenuButton" Click="OnMenuClick"
                    Background="{DynamicResource MainAccentBrush}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ViewDashboard" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuDashboard}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnGames" Classes="MenuButton" Click="OnMenuClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="PackageVariantClosed" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuInventory}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnSales" Classes="MenuButton" Click="OnMenuClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="CashRegister" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuSales}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnOrders" Classes="MenuButton" Click="OnMenuClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ClipboardListOutline" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuOrders}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnAnalytic" Classes="MenuButton" Click="OnMenuClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ChartBar" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuAnalytics}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnSettings" Classes="MenuButton" Click="OnMenuClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="Cog" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuSettings}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Column="1">
            <TransitioningContentControl x:Name="MainContentArea">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.25"/>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>

            <Border VerticalAlignment="Bottom"
                    Background="{DynamicResource PanelBgBrush}"
                    Height="30"
                    Padding="15,0">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="CheckCircle" Width="13" Height="13"
                                         Foreground="{DynamicResource AccentGreenBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="v1.0.5-final-ui"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
