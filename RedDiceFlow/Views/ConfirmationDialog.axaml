<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RedDiceFlow.Views.ConfirmationDialog"
        Title="Confirm"
        Width="380" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" Margin="30">
        <TextBlock x:Name="MessageText" Text="Are you sure?"
                   TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="15"
                   Foreground="{DynamicResource TextPrimary}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
            <Button x:Name="YesButton" Content="Yes" Width="90" Height="36"
                    Background="{DynamicResource MainAccent}" Foreground="White"
                    FontWeight="Bold" CornerRadius="6"/>
            <Button x:Name="NoButton" Content="No" Width="90" Height="36"
                    Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderCol2}"
                    BorderThickness="1" Foreground="{DynamicResource TextPrimary}"
                    CornerRadius="6"/>
        </StackPanel>
    </StackPanel>
</Window>
