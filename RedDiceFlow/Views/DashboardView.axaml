<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Border.StatCard">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Border.StatCard:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="BoxShadow" Value="0 8 24 0 #40000000"/>
        </Style>

        <Style Selector="Button.ActionBtn">
            <Setter Property="Background" Value="{DynamicResource BorderCol2Brush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.ActionBtn:pointerover mi|MaterialIcon">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <mi:MaterialIcon Kind="ViewDashboard" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding L_MenuDashboard}" Classes="Header"
                               FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding L_DashWelcome}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
                <Border Grid.Column="0" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="PackageVariantClosed" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashStock}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="12 Games" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="AlertCircleOutline" Width="13" Height="13"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashStockSub}"
                                       Foreground="{DynamicResource MainAccentBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Cart" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="Orders Today"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="24" Foreground="{DynamicResource MainAccentBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <TextBlock Text="Last update: Just now" Foreground="{DynamicResource TextDimBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="CurrencyUsd" Width="18" Height="18"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                            <TextBlock Text="{Binding L_DashSales}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="$12,450" Foreground="{DynamicResource AccentGreenBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="TrendingUp" Width="13" Height="13"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                            <TextBlock Text="{Binding L_DashSalesSub}"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="2*, *" ColumnSpacing="20">
                <Border Grid.Column="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1" Padding="25">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Quick Order Search" FontWeight="Bold" FontSize="18"/>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Enter Order ID or SKU:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Watermark="e.g. #ORD-7721" Classes="Modern"/>
                        </StackPanel>
                        <Button Content="Check Status" HorizontalAlignment="Stretch" 
                                Background="{DynamicResource MainAccentBrush}" Foreground="White"
                                Height="40" CornerRadius="6" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1" Padding="25">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Recent Sales" FontWeight="Bold" FontSize="18"/>
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="CreditCardOutline" Foreground="{DynamicResource MainAccentBrush}" Width="14"/>
                                <TextBlock Text="Order #1024 paid ($89.00)" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="PackageVariant" Foreground="{DynamicResource TextDimBrush}" Width="14"/>
                                <TextBlock Text="Order #1022 shipped" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="CloseCircleOutline" Foreground="{DynamicResource MainAccentBrush}" Width="14"/>
                                <TextBlock Text="Order #1019 cancelled" FontSize="12" Foreground="{DynamicResource MainAccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1" Padding="25">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="LightningBolt" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{Binding L_DashQuickActions}" FontWeight="Bold"
                                   Foreground="{DynamicResource MainAccentBrush}" FontSize="18"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <WrapPanel Orientation="Horizontal">
                        <Button Classes="ActionBtn" Margin="0,0,15,0" Width="180" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="FileChart" Width="18" Height="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding L_DashBtnReport}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="ActionBtn" Margin="0,0,15,0" Width="180" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="Sync" Width="18" Height="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding L_DashBtnSync}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="ActionBtn" Margin="0,0,15,0" Width="180" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <mi:MaterialIcon Kind="Refresh" Width="18" Height="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding L_DashBtnUpdate}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>