<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RedDiceFlow.Views.DashboardView">
    
    <ScrollViewer>
        <StackPanel Margin="30" Spacing="30">
            <TextBlock Text="Store Dashboard" Classes="Header"/>

            <Grid ColumnDefinitions="*, 20, *, 20, *">
                <Border Grid.Column="0" Background="{StaticResource DarkBgBrush}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Total Products" Foreground="{StaticResource TextDimBrush}" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="📦" FontSize="20"/>
                        </Grid>
                        <TextBlock Text="542" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource DarkBgBrush}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Orders Today" Foreground="{StaticResource TextDimBrush}" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="🛒" FontSize="20"/>
                        </Grid>
                        <TextBlock Text="24" Foreground="{StaticResource MainRedBrush}" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{StaticResource DarkBgBrush}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Revenue (Month)" Foreground="{StaticResource TextDimBrush}" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="💰" FontSize="20"/>
                        </Grid>
                        <TextBlock Text="$12,450" Foreground="#4CAF50" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="1.5*, 30, *">
                <Border Grid.Column="0" Background="{StaticResource DarkBgBrush}" CornerRadius="12" Padding="25" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Quick Order Search" Classes="SubHeader"/>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Enter Order ID or SKU:" Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Name="QuickNoteInput" Classes="Modern" Watermark="e.g. #ORD-7721"/>
                        </StackPanel>
                        <Button Content="Check Status" Background="{StaticResource MainRedBrush}" Foreground="White" Padding="20,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnAddRecordClick"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource DarkBgBrush}" CornerRadius="12" Padding="25" BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Recent Sales" Classes="SubHeader"/>
                        <Border BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                            <TextBlock Text="💳 Order #1024 paid ($89.00)" Foreground="{StaticResource TextDimBrush}" FontSize="13"/>
                        </Border>
                        <Border BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                            <TextBlock Text="📦 Order #1022 shipped" Foreground="{StaticResource TextDimBrush}" FontSize="13"/>
                        </Border>
                        <Border BorderBrush="{StaticResource GrayBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                            <TextBlock Text="❌ Order #1019 cancelled" Foreground="#C3073F" FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>