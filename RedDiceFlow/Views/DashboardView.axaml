<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:views="using:RedDiceFlow.Views"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.DashboardView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <views:StatusToColorConverter x:Key="StatusToColor"/>
        <views:StatusToDisplayConverter x:Key="StatusToDisplay"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.StatCard">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.StatCard:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="BoxShadow" Value="0 8 24 0 #40000000"/>
        </Style>

        <Style Selector="Button.ActionBtn">
            <Setter Property="Background" Value="{DynamicResource BorderCol2Brush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover mi|MaterialIcon">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <mi:MaterialIcon Kind="ViewDashboard" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_MenuDashboard}" Classes="Header"
                               FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource L_DashWelcome}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
                <Border Grid.Column="0" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="PackageVariantClosed" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{DynamicResource L_DashStock}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalProducts, StringFormat='{}{0} Games'}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="AlertCircleOutline" Width="13" Height="13"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{DynamicResource L_DashStockSub}"
                                       Foreground="{DynamicResource MainAccentBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Cart" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{DynamicResource L_DashSales}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DashboardSalesToday, StringFormat='{}{0:N2} $'}"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="TrendingUp" Width="13" Height="13"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{DynamicResource L_DashSalesSub}"
                                       Foreground="{DynamicResource MainAccentBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="CurrencyUsd" Width="18" Height="18"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                            <TextBlock Text="{DynamicResource L_DashActiveStock}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalStock, StringFormat='{}{0} units'}"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   FontSize="32" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="CheckCircle" Width="13" Height="13"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                            <TextBlock Text="{DynamicResource L_StatusOk}"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="2*, *" ColumnSpacing="20">
                <Border Grid.Column="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1" Padding="25">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{DynamicResource L_DashQuickSearch}" FontWeight="Bold" FontSize="18"/>
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource L_DashQuickSearchSub}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" PlaceholderText="{DynamicResource L_DashQuickSearchPlaceholder}"
                                         Text="{Binding QuickSearchText}"
                                         Background="{DynamicResource PanelBgBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush2}"
                                         Height="38"/>
                                <Button Grid.Column="1"
                                        Command="{Binding QuickSearchOrderCommand}"
                                        Content="{DynamicResource L_OrderSearchButton}"
                                        Background="{DynamicResource MainAccentBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Padding="16,0"/>
                            </Grid>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding QuickSearchResults}"
                                      IsVisible="{Binding HasQuickSearchResult}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush2}"
                                            BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToDisplay}}"
                                                               FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OrderNumber}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource MainAccentBrush}"/>
                                                <TextBlock Text="{Binding CustomerName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalPrice, StringFormat='{}{0:N2} $'}"
                                                       Foreground="{DynamicResource AccentGreenBrush}"
                                                       FontWeight="Bold" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        BorderBrush="{DynamicResource BorderCol2Brush}" BorderThickness="1" Padding="25">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{DynamicResource L_RecentOrders}" FontWeight="Bold" FontSize="18"/>

                        <ItemsControl ItemsSource="{Binding RecentOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush2}"
                                            BorderThickness="0,0,0,1" Padding="0,10,0,10">
                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToDisplay}}"
                                                               FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OrderNumber}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource MainAccentBrush}"/>
                                                <TextBlock Text="{Binding CustomerName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding CustomerPhone}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{DynamicResource L_NoRecentOrders}"
                                   IsVisible="{Binding HasNoRecentOrders}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="25">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Trophy" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{DynamicResource L_DashTopGames}" FontWeight="Bold"
                                   Foreground="{DynamicResource MainAccentBrush}" FontSize="18"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding TopSellingGames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush2}"
                                        BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="15">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TotalSold, StringFormat='x{0}'}"
                                                   Foreground="{DynamicResource MainAccentBrush}"
                                                   FontWeight="Bold" FontSize="14"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Genre}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TotalRevenue, StringFormat='{}{0:N2} $'}"
                                                   Foreground="{DynamicResource AccentGreenBrush}"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
