<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="ViewDashboard" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding L_MenuDashboard}" Classes="Header"
                               FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding L_DashWelcome}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
                <Border Grid.Column="0" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush3}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="CurrencyUsd" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashSales}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="$12,840.50" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="30" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="TrendingUp" Width="13" Height="13"
                                             Foreground="{DynamicResource AccentGreenBrush}"/>
                            <TextBlock Text="{Binding L_DashSalesSub}"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush3}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="PackageVariantClosed" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashStock}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="142 Games" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="30" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="AlertCircleOutline" Width="13" Height="13"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashStockSub}"
                                       Foreground="{DynamicResource MainAccentBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource PanelBgBrush}" Padding="25"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush3}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Wifi" Width="18" Height="18"
                                             Foreground="{DynamicResource MainAccentBrush}"/>
                            <TextBlock Text="{Binding L_DashStatus}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Online" Foreground="{DynamicResource AccentGreenBrush}"
                                   FontSize="30" FontWeight="Black"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="CheckCircleOutline" Width="13" Height="13"
                                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding L_DashStatusSub}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush3}" BorderThickness="1" Padding="25">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="LightningBolt" Width="20" Height="20"
                                         Foreground="{DynamicResource MainAccentBrush}"/>
                        <TextBlock Text="{Binding L_DashQuickActions}" FontWeight="Bold"
                                   Foreground="{DynamicResource MainAccentBrush}" FontSize="18"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <WrapPanel Orientation="Horizontal">
                        <Button Classes="MenuButton" Margin="0,0,15,15" Width="200" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="FileChart" Width="18" Height="18"/>
                                <TextBlock Text="{Binding L_DashBtnReport}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="MenuButton" Margin="0,0,15,15" Width="200" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="Sync" Width="18" Height="18"/>
                                <TextBlock Text="{Binding L_DashBtnSync}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="MenuButton" Margin="0,0,15,15" Width="200" Height="45">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="Refresh" Width="18" Height="18"/>
                                <TextBlock Text="{Binding L_DashBtnUpdate}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>