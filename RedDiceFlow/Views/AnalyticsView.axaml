<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RedDiceFlow.Views.AnalyticsView">
    
    <ScrollViewer>
        <StackPanel Margin="30" Spacing="30">
            <TextBlock Text="Performance Analytics" Foreground="White" FontSize="32" FontWeight="Heavy"/>

            <Grid ColumnDefinitions="*, 20, *" RowDefinitions="300, 20, 300">
                <Border Grid.Row="0" Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#252525" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Revenue Overview" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Monthly earnings tracking" Foreground="#888888" FontSize="12"/>
                        <Separator Background="#252525" Margin="0,10"/>
                        <TextBlock Text="[ LINE CHART PLACEHOLDER ]" Foreground="#2A1015" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50" FontSize="20"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#252525" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Popular Categories" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Sales distribution by genre" Foreground="#888888" FontSize="12"/>
                        <Separator Background="#252525" Margin="0,10"/>
                        <TextBlock Text="[ PIE CHART PLACEHOLDER ]" Foreground="#2A1015" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50" FontSize="20"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#252525" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Loan Traffic" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Peak hours for board game rentals" Foreground="#888888" FontSize="12"/>
                        <Separator Background="#252525" Margin="0,10"/>
                        <TextBlock Text="[ BAR CHART PLACEHOLDER ]" Foreground="#2A1015" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50" FontSize="20"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>