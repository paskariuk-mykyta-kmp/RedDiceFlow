<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.AnalyticsView"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource AppBgBrush}">

    <UserControl.Styles>
        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush2}"/>
        </Style>
        <Style Selector="Border.StatCard">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.StatCard:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource MainAccentBrush}"/>
            <Setter Property="BoxShadow" Value="0 8 24 0 #40000000"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <mi:MaterialIcon Kind="TrendingUp" Width="28" Height="28"
                                         Foreground="{DynamicResource MainAccentBrush}"
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_AnalyticsHeader}" Classes="Header"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource L_AnalyticsSub}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource L_ReportPeriodLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding ReportPeriods}"
                              SelectedIndex="{Binding SelectedReportPeriodIndex}"
                              Width="140"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Classes="Modern"/>
                    <Button Command="{Binding CreateManagerReport}"
                            Background="{DynamicResource MainAccentBrush}"
                            Foreground="White"
                            Padding="22,10"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="FilePdfBox" Width="18" Height="18" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource L_CreatePdf}" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
                <Border Grid.Column="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        Padding="18" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="PackageVariantClosed" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}" HorizontalAlignment="Center"/>
                         <TextBlock Text="{DynamicResource L_ProductsMetric}" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        Padding="18" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="Warehouse" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_StockMetric}" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalStock}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        Padding="18" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="CartCheck" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_SoldMetric}" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SoldItems}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                    Padding="20" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="ChartTimelineVariant" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}"
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_Infographic}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="160, *, 60" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{DynamicResource L_StockLoad}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                                     Value="{Binding StockLoadPercent}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding StockLoadPercent, StringFormat='{}{0:N0}%'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="160, *, 60" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{DynamicResource L_SalesProgress}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                                     Value="{Binding SalesProgressPercent}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SalesProgressPercent, StringFormat='{}{0:N0}%'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="160, *, 60" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{DynamicResource L_LowStockRisk}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                                     Value="{Binding LowStockRiskPercent}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding LowStockRiskPercent, StringFormat='{}{0:N0}%'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                <Border Grid.Column="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        Padding="20" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{DynamicResource L_RecentOrders}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{DynamicResource L_NoRecentOrders}"
                                   IsVisible="{Binding HasNoRecentOrders}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <ItemsControl ItemsSource="{Binding RecentOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Order">
                                    <Grid ColumnDefinitions="Auto, 2*, 1*, 1*" Margin="0,6" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayNumber, StringFormat='#{0}'}"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource MainAccentBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CustomerName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat='{}{0:N2} $'}"
                                                   Foreground="{DynamicResource AccentGreenBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM HH:mm}'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}" CornerRadius="12"
                        Padding="20" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{DynamicResource L_LowStock}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <ItemsControl ItemsSource="{Binding LowStockProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Product">
                                    <Grid ColumnDefinitions="2*, 1*" Margin="0,6">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Stock, StringFormat='{}{0} left'}"
                                                   Foreground="{DynamicResource MainAccentBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*, *, *, *, *" ColumnSpacing="15">
                <Border Grid.Column="0" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="18"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="PackageVariantClosed" Width="22" Height="22"
                                         Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_StockValue}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalStockValue, StringFormat='{}{0:N2} $'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreenBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="18"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="Cart" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Sales Today"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SalesToday, StringFormat='{}{0:N2} $'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource MainAccentBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="18"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="CalendarWeek" Width="22" Height="22"
                                         Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="This Week"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SalesThisWeek, StringFormat='{}{0:N2} $'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreenBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="18"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="CalendarMonth" Width="22" Height="22"
                                         Foreground="{DynamicResource MainAccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="This Month"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SalesThisMonth, StringFormat='{}{0:N2} $'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource MainAccentBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Classes="StatCard" Background="{DynamicResource PanelBgBrush}" Padding="18"
                        CornerRadius="12" BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="CashMultiple" Width="22" Height="22"
                                         Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_RevenueMetric}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SalesTotal, StringFormat='{}{0:N2} $'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreenBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
