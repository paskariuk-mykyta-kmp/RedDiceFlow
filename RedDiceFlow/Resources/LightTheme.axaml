<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="MainAccent">#1565C0</Color>
    <Color x:Key="AppBg">#F0F2F5</Color>
    <Color x:Key="PanelBg">#FFFFFF</Color>
    <Color x:Key="BorderCol">#E0E0E0</Color>
    <Color x:Key="BorderCol2">#CCCCCC</Color>
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="TextDimCol">#9E9E9E</Color>
    <Color x:Key="AccentGreen">#2E7D32</Color>
    <Color x:Key="TableHeaderBg">#F5F5F5</Color>
    <Color x:Key="HoverBg">#EEF2FF</Color>
    <Color x:Key="BadgeBg">#E8F5E9</Color>

    <SolidColorBrush x:Key="MainAccentBrush"    Color="#1565C0"/>
    <SolidColorBrush x:Key="AppBgBrush"         Color="#F0F2F5"/>
    <SolidColorBrush x:Key="PanelBgBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush2"       Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BorderBrush3"       Color="#CCCCCC"/>
    <SolidColorBrush x:Key="BorderCol2Brush"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
    <SolidColorBrush x:Key="TextDimBrush"       Color="#777777"/>
    <SolidColorBrush x:Key="AccentGreenBrush"   Color="#2E7D32"/>
    <SolidColorBrush x:Key="AccentRedBrush"     Color="#D32F2F"/>
    <SolidColorBrush x:Key="TableHeaderBgBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="HoverBgBrush"       Color="#EEF2FF"/>
    <SolidColorBrush x:Key="BadgeBgBrush"       Color="#E8F5E9"/>
</ResourceDictionary>