<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="MainAccent">#C3073F</Color>
    <Color x:Key="AppBg">#121212</Color>
    <Color x:Key="PanelBg">#1A1A1A</Color>
    <Color x:Key="BorderCol">#252525</Color>
    <Color x:Key="BorderCol2">#333333</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#666666</Color>
    <Color x:Key="TextDimCol">#888888</Color>
    <Color x:Key="AccentGreen">#00FF41</Color>
    <Color x:Key="TableHeaderBg">#252525</Color>
    <Color x:Key="HoverBg">#1F1F1F</Color>
    <Color x:Key="BadgeBg">#252525</Color>

    <SolidColorBrush x:Key="MainAccentBrush"    Color="#C3073F"/>
    <SolidColorBrush x:Key="AppBgBrush"         Color="#121212"/>
    <SolidColorBrush x:Key="PanelBgBrush"       Color="#1A1A1A"/>
    <SolidColorBrush x:Key="BorderBrush2"       Color="#252525"/>
    <SolidColorBrush x:Key="BorderBrush3"       Color="#333333"/>
    <SolidColorBrush x:Key="BorderCol2Brush"    Color="#252525"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="TextDimBrush"       Color="#888888"/>
    <SolidColorBrush x:Key="AccentGreenBrush"   Color="#00FF41"/>
    <SolidColorBrush x:Key="AccentRedBrush"     Color="#FF5252"/>
    <SolidColorBrush x:Key="TableHeaderBgBrush" Color="#252525"/>
    <SolidColorBrush x:Key="HoverBgBrush"       Color="#1F1F1F"/>
    <SolidColorBrush x:Key="BadgeBgBrush"       Color="#252525"/>
</ResourceDictionary>