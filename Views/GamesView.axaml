<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.GamesView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Border.TableRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TableRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="30" Spacing="25">

        <!-- Header -->
        <Grid ColumnDefinitions="*, Auto, 10, Auto">
            <StackPanel Grid.Column="0" Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="PackageVariantClosed" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccent}"
                                     VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding L_InventoryHeader}" Classes="Header" VerticalAlignment="Center" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="{Binding L_InventorySub}" Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
            </StackPanel>

            <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortMode}" VerticalAlignment="Bottom" Width="170"
                      Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderCol2}"
                      CornerRadius="6" Height="35"/>

            <TextBox Grid.Column="3" Width="250" PlaceholderText="{Binding L_SearchWatermark}" Text="{Binding SearchText}" Classes="Modern" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Add / Edit form -->
        <Border Background="{DynamicResource PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource BorderCol2}" BorderThickness="1" Padding="20">
            <StackPanel Spacing="15">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="PlusCircleOutline" Foreground="{DynamicResource MainAccent}" Width="20" Height="20"/>
                    <TextBlock Text="{Binding L_QuickAdd}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EditTargetProduct.Name, StringFormat='✎ {0}'}" FontWeight="Bold" FontSize="16"
                               Foreground="{DynamicResource MainAccent}" IsVisible="{Binding IsEditMode}"/>
                </StackPanel>

                <Grid ColumnDefinitions="1.5*, 1*, 1*, 1*, 1*, 1*, Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="{Binding L_NameLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox Classes="ModernInput" Text="{Binding NewName}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="{Binding L_SkuLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox Classes="ModernInput" Text="{Binding NewSku}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="5">
                        <TextBlock Text="{Binding L_PriceLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox Classes="ModernInput" Text="{Binding NewPrice}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="5">
                        <TextBlock Text="{Binding L_StockLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox Classes="ModernInput" Text="{Binding NewStock}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="5">
                        <TextBlock Text="{Binding L_GenreLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <ComboBox ItemsSource="{Binding GenreOptions}" SelectedItem="{Binding NewGenre}" Height="35"
                                  Background="{DynamicResource AppBg}" BorderBrush="{DynamicResource BorderCol2}"
                                  CornerRadius="6" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="5" Spacing="5">
                        <TextBlock Text="{Binding L_PlayersLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <ComboBox ItemsSource="{Binding PlayersCountOptions}" SelectedItem="{Binding NewPlayersCount}" Height="35"
                                  Background="{DynamicResource AppBg}" BorderBrush="{DynamicResource BorderCol2}"
                                  CornerRadius="6" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                        <Button Command="{Binding AddProduct}" 
                                Height="35" Padding="16,0"
                                Background="{DynamicResource MainAccent}" Foreground="White" 
                                FontWeight="Bold"
                                Content="{Binding L_ConfirmBtn}"
                                IsVisible="{Binding !IsEditMode}"/>
                        <Button Command="{Binding AddProduct}" 
                                Height="35" Padding="16,0"
                                Background="{DynamicResource MainAccent}" Foreground="White" 
                                FontWeight="Bold"
                                Content="{Binding L_SaveBtn}"
                                IsVisible="{Binding IsEditMode}"/>
                        <Button Command="{Binding CancelEditCommand}"
                                Height="35" Padding="16,0"
                                Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderCol2}"
                                BorderThickness="1" Foreground="{DynamicResource TextPrimary}"
                                Content="{Binding L_CancelBtn}"
                                IsVisible="{Binding IsEditMode}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Table -->
        <Border Background="{DynamicResource PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource BorderCol2}" BorderThickness="1" ClipToBounds="True">
            <StackPanel>
                <Border Background="{DynamicResource TableHeaderBg}" Padding="20,12">
                    <Grid ColumnDefinitions="1.5*, 0.8*, 0.8*, 0.8*, 0.8*, 1.5*">
                        <TextBlock Grid.Column="0" Text="{Binding L_TableProduct}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="1" Text="{Binding L_TablePrice}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="2" Text="{Binding L_TableStock}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="3" Text="{Binding L_TablePlayers}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="4" Text="{Binding L_TableStatus}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy"/>
                        <TextBlock Grid.Column="5" Text="{Binding L_TableActions}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Heavy" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Product">
                            <Border Padding="20,12" Background="Transparent" BorderBrush="{DynamicResource BorderCol}" BorderThickness="0,0,0,1" Classes="TableRow">
                                <Grid ColumnDefinitions="1.5*, 0.8*, 0.8*, 0.8*, 0.8*, 1.5*">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Genre}" FontSize="10" Foreground="{DynamicResource MainAccent}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='{}{0:N2}'}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Stock, StringFormat='{}{0} pcs'}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PlayersCount}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                    <Border Grid.Column="4" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{DynamicResource BadgeBg}" IsVisible="{Binding IsLowStock}">
                                        <TextBlock Text="{Binding StockStatusText}" FontSize="10" FontWeight="Bold" Foreground="#e74c3c"/>
                                    </Border>
                                    <Border Grid.Column="4" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{DynamicResource BadgeBg}" IsVisible="{Binding !IsLowStock}">
                                        <TextBlock Text="{Binding StockStatusText}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentGreen}"/>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                        <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).EditProductCommand}"
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Width="30" Height="30">
                                            <mi:MaterialIcon Kind="PencilOutline" Foreground="{DynamicResource MainAccent}"/>
                                        </Button>
                                        <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).RestockProductCommand}"
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Width="30" Height="30"
                                                FontWeight="Bold" Foreground="{DynamicResource AccentGreen}"
                                                Content="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).L_RestockBtn}"/>
                                        <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).DeleteProductCommand}"
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Width="30" Height="30">
                                            <mi:MaterialIcon Kind="TrashCanOutline" Foreground="#e74c3c"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
