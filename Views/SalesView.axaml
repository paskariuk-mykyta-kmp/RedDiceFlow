<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedDiceFlow.ViewModels"
             xmlns:models="using:RedDiceFlow.Models"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="RedDiceFlow.Views.SalesView"
             x:CompileBindings="False"
             Background="{DynamicResource AppBgBrush}">

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="CashRegister" Width="28" Height="28"
                                     Foreground="{DynamicResource MainAccentBrush}"/>
                    <TextBlock Text="{Binding L_SalesHeader}"
                               Classes="Header"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding L_SalesSub}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Grid ColumnDefinitions="1.5*, 1*" ColumnSpacing="20">
                <Border Grid.Column="0"
                        Background="{DynamicResource PanelBgBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding L_SearchProductPlaceholder}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBox Text="{Binding SaleSearchText}"
                                 PlaceholderText="{Binding L_SearchProductPlaceholder}"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"
                                 Height="38"/>

                        <ScrollViewer MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding FilteredProductsForSale}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush2}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,6">
                                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} $'}"
                                                                   Foreground="{DynamicResource AccentGreenBrush}"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding Stock, StringFormat='{}{0} pcs'}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding Genre}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="13"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBox Grid.Column="1"
                                                         Width="60"
                                                         Height="34"
                                                         Text="{Binding DataContext.CartQuantity, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                         Background="{DynamicResource PanelBgBrush}"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                                         BorderBrush="{DynamicResource BorderBrush2}"/>
                                                <Button Grid.Column="2"
                                                        Background="{DynamicResource MainAccentBrush}"
                                                        Foreground="White"
                                                        Height="34"
                                                        Padding="12,0"
                                                        Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <mi:MaterialIcon Kind="CartPlus" Width="16" Height="16" Foreground="White"/>
                                                        <TextBlock Text="{Binding DataContext.L_AddToCart, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                                   Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource PanelBgBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush2}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding L_CartHeader}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding L_CartEmpty}"
                                   IsVisible="{Binding IsCartEmpty}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <ScrollViewer MaxHeight="250">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush2}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,6">
                                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ProductName}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Quantity, StringFormat='x{0}'}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding UnitPrice, StringFormat='@ {0:N2} $'}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding LineTotal, StringFormat='{}{0:N2} $'}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentGreenBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{DynamicResource AccentRedBrush}"
                                                        FontSize="18"
                                                        VerticalAlignment="Center"
                                                        Padding="4,0"
                                                        Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding DataContext.L_RemoveFromCart, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Background="{DynamicResource AppBgBrush}"
                                CornerRadius="8"
                                Padding="12,8">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{Binding L_CartTotal}"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CartTotalPrice, StringFormat='{}{0:N2} $'}"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                            </Grid>
                        </Border>

                        <Separator Background="{DynamicResource BorderBrush2}" Height="1"/>

                        <TextBlock Text="{Binding L_CustomerSearchLabel}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBox Text="{Binding CustomerSearchText}"
                                 PlaceholderText="{Binding L_CustomerSearchLabel}"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"
                                 Height="38"/>

                        <ItemsControl ItemsSource="{Binding FoundCustomers}" MaxHeight="120">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush2}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Phone}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBox Text="{Binding NewCustomerName}"
                                 IsVisible="{Binding ShowNewCustomerField}"
                                 PlaceholderText="{Binding L_CustomerNewName}"
                                 Background="{DynamicResource PanelBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"
                                 Height="38"/>

                        <Button Command="{Binding PlaceOrderCommand}"
                                Background="{DynamicResource MainAccentBrush}"
                                Foreground="White"
                                Height="44"
                                Padding="12,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="CashRegister" Width="20" Height="20" Foreground="White"/>
                                <TextBlock Text="{Binding L_PlaceOrder}" Foreground="White" FontSize="15"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBgBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding L_RecentOrders}"
                               FontWeight="Bold"
                               FontSize="18"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="{Binding L_NoRecentOrders}"
                               IsVisible="{Binding HasNoRecentOrders}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <ItemsControl ItemsSource="{Binding RecentOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush2}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid ColumnDefinitions="Auto, 1.5*, 1*, 1*, Auto" ColumnSpacing="12">
                                        <TextBlock Grid.Column="0"
Text="{Binding DisplayNumber, StringFormat='#{0}'}"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource MainAccentBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CustomerName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalPrice, StringFormat='{}{0:N2} $'}"
                                                   Foreground="{DynamicResource AccentGreenBrush}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM HH:mm}'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Button Grid.Column="4"
                                                Background="{DynamicResource AccentRedBrush}"
                                                Foreground="White"
                                                Height="30"
                                                Padding="8,0"
                                                FontSize="12"
                                                Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding DataContext.L_CancelOrder, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                       Foreground="White"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
